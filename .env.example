# Copy to .env on the DGX or export these in the worker shell.
# Do not commit real secrets or machine-specific passwords.

MISSION_DB_PATH=/home/asus/sqlite/mission.db
# SPATIALITE_PATH=/usr/lib/aarch64-linux-gnu/mod_spatialite.so

# Used by workers/agent.py. The routing worker sends one prompt per searcher
# to this command over stdin and expects a tiny JSON target-cell response.
# The script locates the OpenClaw sandbox container and invokes OpenClaw inside it.
OPENCLAW_ROUTER_COMMAND=/home/asus/geo-beacon/scripts/run_openclaw_router.sh
OPENCLAW_SANDBOX_NAME=my-assistant
OPENCLAW_COMMAND=
OPENCLAW_PROMPT_PATH=/home/asus/geo-beacon/openclaw/agent_prompt.md
OPENCLAW_TIMEOUT_SECONDS=180
AGENT_EVENT_WINDOW_SECONDS=90
ROUTING_AGENT_CONCURRENCY=3
ROUTING_AGENT_INTERVAL_SECONDS=30
ROUTING_AGENT_LOG_PATH=/tmp/geo-beacon/routing-agent.jsonl

# Ollama endpoint for OpenClaw/config templates.
OLLAMA_BASE_URL=http://127.0.0.1:11434
