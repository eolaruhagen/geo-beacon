# Copy to .env on the DGX or export these in the worker shell.
# Do not commit real secrets or machine-specific passwords.

MISSION_DB_PATH=/home/asus/sqlite/mission.db
# SPATIALITE_PATH=/usr/lib/aarch64-linux-gnu/mod_spatialite.so

# Used by workers/agent.py. Set this after OpenClaw is installed.
# Example shape only; adapt to the actual CLI/config you use:
# OPENCLAW_COMMAND=openclaw run --config /home/asus/geo-beacon/openclaw/config.toml
OPENCLAW_COMMAND=
OPENCLAW_PROMPT_PATH=/home/asus/geo-beacon/openclaw/agent_prompt.md
OPENCLAW_TIMEOUT_SECONDS=180
AGENT_EVENT_WINDOW_SECONDS=90

# Ollama endpoint for OpenClaw/config templates.
OLLAMA_BASE_URL=http://127.0.0.1:11434

